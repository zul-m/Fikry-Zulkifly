---
import { Search, ChevronDown, ArrowUpDown, SlidersHorizontal } from '@lucide/astro';
---

<form class="filter-bar" role="search" onsubmit="return false;">
  <label class="filter-bar__search">
    <span class="filter-bar__icon" aria-hidden="true">
      <Search size={24} />
    </span>
    <input type="search" name="q" placeholder="Cari lokasi" autocomplete="off" />
  </label>
  <button class="filter-bar__toggle" type="button" aria-expanded="false" aria-controls="filter-bar-buttons" aria-label="Tapis">
    <span class="filter-bar__icon" aria-hidden="true">
      <SlidersHorizontal size={24} />
    </span>
    <span class="filter-bar__badge" aria-hidden="true"></span>
  </button>
  <div class="filter-bar__buttons" id="filter-bar-buttons">
    <div class="filter-bar__dropdown-wrap">
      <button class="filter-bar__select" type="button" aria-haspopup="listbox" aria-expanded="false" id="location-btn">
        <span>Pilih lokasi</span>
        <span class="filter-bar__icon" aria-hidden="true">
          <ChevronDown size={24} />
        </span>
        <span class="filter-bar__badge" aria-hidden="true"></span>
      </button>
      <ul class="filter-bar__dropdown" role="listbox" aria-labelledby="location-btn">
        <li role="option" aria-selected="true" data-value="">Semua</li>
        <li role="option" aria-selected="false" data-value="Cyberjaya, Selangor">Cyberjaya, Selangor</li>
        <li role="option" aria-selected="false" data-value="Salak Tinggi, Selangor">Salak Tinggi, Selangor</li>
      </ul>
    </div>
    <button class="filter-bar__select" type="button" aria-haspopup="listbox">
      <span>Pilih jenis</span>
      <span class="filter-bar__icon" aria-hidden="true">
        <ChevronDown size={24} />
      </span>
      <span class="filter-bar__badge" aria-hidden="true"></span>
    </button>
    <button class="filter-bar__select" type="button" aria-haspopup="listbox">
      <span>Pilih harga</span>
      <span class="filter-bar__icon" aria-hidden="true">
        <ChevronDown size={24} />
      </span>
      <span class="filter-bar__badge" aria-hidden="true"></span>
    </button>
  </div>
  <button class="filter-bar__sort" type="button" aria-label="Susun mengikut">
    <span class="filter-bar__icon" aria-hidden="true">
      <ArrowUpDown size={24} />
    </span>
  </button>
</form>

<style>
  /* ── Grid structure (mobile) ─────────────────────────────── */
  .filter-bar {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    column-gap: var(--space-3);
    row-gap: var(--space-3);
  }

  .filter-bar__search  { grid-column: 1; grid-row: 1; }
  .filter-bar__toggle  { grid-column: 2; grid-row: 1; }
  .filter-bar__sort    { grid-column: 3; grid-row: 1; }
  .filter-bar__buttons {
    grid-column: 1 / -1;
    grid-row: 2;
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
  }

  /* ── Shared appearance ──────────────────────────────────── */
  .filter-bar__search,
  .filter-bar__select,
  .filter-bar__toggle {
    height: 3rem;
    border-radius: var(--radius-small);
    background: var(--color-light-200);
    border: var(--border-width-main) solid var(--theme-border);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0 var(--space-2);
  }

  .filter-bar__select { width: 100%; }

  /* ── Revealed when panel is open ────────────────────────── */
  .filter-bar.is-open .filter-bar__buttons { display: flex; }

  /* ── Desktop ─────────────────────────────────────────────── */
  @media (min-width: 48rem) {
    .filter-bar {
      grid-template-columns: repeat(3, 1fr);
      align-items: center;
      gap: var(--space-3);
      position: relative;
    }

    .filter-bar__toggle  { display: none; }
    .filter-bar__search  { grid-column: 1;      grid-row: 1; }
    .filter-bar__buttons { grid-column: 2 / -1; grid-row: 1; display: flex; flex-direction: row; align-items: center; gap: var(--space-3); padding-right: calc(1.5rem + var(--space-3)); }
    .filter-bar__sort    { position: absolute; right: 0; top: 50%; transform: translateY(-50%); }

    .filter-bar__select { flex: 1 1 0; width: auto; min-width: 0; }
  }

  @media (min-width: 64rem) {
    .filter-bar { gap: var(--space-6); }
    .filter-bar__buttons { gap: var(--space-6); padding-right: calc(1.5rem + var(--space-6)); }
  }

  /* ── Component styles ───────────────────────────────────── */
  .filter-bar__search { cursor: text; }

  .filter-bar__search input {
    flex: 1 1 auto;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-huge);
    color: var(--theme-text);
  }
  .filter-bar__search input::placeholder {
    color: color-mix(in srgb, var(--theme-text) 40%, transparent);
  }

  .filter-bar__toggle {
    cursor: pointer;
    color: var(--theme-text);
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-huge);
    transition: border-color .2s ease;
    position: relative;
  }
  .filter-bar__toggle:hover { border-color: var(--theme-text); }

  .filter-bar__select {
    justify-content: space-between;
    color: var(--theme-text);
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-huge);
    cursor: pointer;
    transition: border-color .2s ease;
    position: relative;
  }

  .filter-bar__select > span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .filter-bar__select:hover { border-color: var(--theme-text); }

  .filter-bar__sort {
    background: transparent;
    border: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    height: 1.5rem;
    cursor: pointer;
    color: var(--theme-text);
  }

  .filter-bar__icon {
    width: 1.5rem;
    height: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--theme-text);
    flex-shrink: 0;
  }

  .filter-bar__badge {
    position: absolute;
    top: -0.375rem;
    right: -0.375rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--color-brand-400);
    border: 0.125rem solid var(--color-light-200);
    display: none;
    pointer-events: none;
  }

  .filter-bar__select.has-value .filter-bar__badge,
  .filter-bar__toggle.has-value .filter-bar__badge {
    display: block;
  }

  /* ── Location dropdown ─────────────────────────────────── */
  .filter-bar__dropdown-wrap {
    position: relative;
    width: 100%;
  }

  .filter-bar__dropdown-wrap .filter-bar__select {
    width: 100%;
  }

  .filter-bar__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: var(--space-2);
    list-style: none;
    margin-inline: 0;
    padding: var(--space-2) 0;
    background: var(--color-light-200);
    border: var(--border-width-main) solid var(--theme-border);
    border-radius: var(--radius-small);
    z-index: 10;
    display: none;
  }

  .filter-bar__dropdown-wrap.is-open .filter-bar__dropdown {
    display: block;
  }

  .filter-bar__dropdown [role="option"] {
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    color: var(--theme-text);
  }

  .filter-bar__dropdown [role="option"]:hover {
    background: color-mix(in srgb, var(--theme-text) 8%, transparent);
  }

  .filter-bar__dropdown [role="option"][aria-selected="true"] {
    background: color-mix(in srgb, var(--theme-text) 12%, transparent);
  }

  @media (min-width: 48rem) {
    .filter-bar__dropdown-wrap {
      flex: 1 1 0;
      width: auto;
      min-width: 0;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('.filter-bar');
  const toggle = form?.querySelector<HTMLButtonElement>('.filter-bar__toggle');

  toggle?.addEventListener('click', () => {
    const open = form!.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  const locationWrap = document.querySelector<HTMLElement>('.filter-bar__dropdown-wrap');
  const locationBtn  = locationWrap?.querySelector<HTMLButtonElement>('.filter-bar__select');
  const locationList = locationWrap?.querySelector<HTMLElement>('.filter-bar__dropdown');
  const locationLabel = locationBtn?.querySelector<HTMLSpanElement>('span:first-child');

  locationBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = locationWrap!.classList.toggle('is-open');
    locationBtn.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', () => {
    locationWrap?.classList.remove('is-open');
    locationBtn?.setAttribute('aria-expanded', 'false');
  });

  locationList?.querySelectorAll<HTMLElement>('[role="option"]').forEach((option) => {
    option.addEventListener('click', (e) => {
      e.stopPropagation();
      const value = option.dataset.value ?? '';

      locationList.querySelectorAll('[role="option"]').forEach(o =>
        o.setAttribute('aria-selected', 'false')
      );
      option.setAttribute('aria-selected', 'true');

      locationLabel!.textContent = value || 'Pilih lokasi';
      locationBtn!.classList.toggle('has-value', value !== '');
      toggle?.classList.toggle('has-value', value !== '');
      filterLocation(value);

      locationWrap!.classList.remove('is-open');
      locationBtn!.setAttribute('aria-expanded', 'false');
    });
  });

  function filterLocation(value: string) {
    document.querySelectorAll<HTMLElement>('[data-location]').forEach((item) => {
      item.hidden = value !== '' && item.dataset.location !== value;
    });
  }
</script>
