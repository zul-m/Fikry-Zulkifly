---
import { Search, ChevronDown, ArrowUpDown, SlidersHorizontal } from '@lucide/astro';

interface FilterOption {
  value: string;
  label: string;
}
interface Props {
  locationOptions: FilterOption[];
  typeOptions: FilterOption[];
}
const { locationOptions, typeOptions } = Astro.props;
---

<form class="filter-bar" role="search" onsubmit="return false;">
  <label class="filter-bar__search">
    <span class="filter-bar__icon" aria-hidden="true">
      <Search size={24} />
    </span>
    <input type="search" name="q" placeholder="Cari hartanah" autocomplete="off" />
  </label>
  <button class="filter-bar__toggle" type="button" aria-expanded="false" aria-controls="filter-bar-buttons" aria-label="Tapis">
    <span class="filter-bar__icon" aria-hidden="true">
      <SlidersHorizontal size={24} />
    </span>
    <span class="filter-bar__badge" aria-hidden="true"></span>
  </button>
  <div class="filter-bar__buttons" id="filter-bar-buttons">
    <div class="filter-bar__dropdown-wrap" data-filter-group="location">
      <button class="filter-bar__select" type="button" aria-haspopup="listbox" aria-expanded="false" id="location-btn">
        <span>Pilih lokasi</span>
        <span class="filter-bar__icon" aria-hidden="true">
          <ChevronDown size={24} />
        </span>
        <span class="filter-bar__badge" aria-hidden="true"></span>
      </button>
      <ul class="filter-bar__dropdown" role="listbox" aria-labelledby="location-btn">
        <li role="option" aria-selected="true" data-value="">Semua</li>
        {locationOptions.map(opt => (
          <li role="option" aria-selected="false" data-value={opt.value}>{opt.label}</li>
        ))}
      </ul>
    </div>
    <div class="filter-bar__dropdown-wrap" data-filter-group="type">
      <button class="filter-bar__select" type="button" aria-haspopup="listbox" aria-expanded="false" id="type-btn">
        <span>Pilih jenis</span>
        <span class="filter-bar__icon" aria-hidden="true">
          <ChevronDown size={24} />
        </span>
        <span class="filter-bar__badge" aria-hidden="true"></span>
      </button>
      <ul class="filter-bar__dropdown" role="listbox" aria-labelledby="type-btn">
        <li role="option" aria-selected="true" data-value="">Semua</li>
        {typeOptions.map(opt => (
          <li role="option" aria-selected="false" data-value={opt.value}>{opt.label}</li>
        ))}
      </ul>
    </div>
    <div class="filter-bar__dropdown-wrap" data-filter-group="price">
      <button class="filter-bar__select" type="button" aria-haspopup="listbox" aria-expanded="false" id="price-btn">
        <span>Pilih harga</span>
        <span class="filter-bar__icon" aria-hidden="true">
          <ChevronDown size={24} />
        </span>
        <span class="filter-bar__badge" aria-hidden="true"></span>
      </button>
      <ul class="filter-bar__dropdown" role="listbox" aria-labelledby="price-btn">
        <li role="option" aria-selected="true" data-value="">Semua</li>
        <li role="option" aria-selected="false" data-value="200-299">RM 200k – RM 299k</li>
        <li role="option" aria-selected="false" data-value="300-399">RM 300k – RM 399k</li>
        <li role="option" aria-selected="false" data-value="400-499">RM 400k – RM 499k</li>
        <li role="option" aria-selected="false" data-value="500-599">RM 500k – RM 599k</li>
        <li role="option" aria-selected="false" data-value="600-699">RM 600k – RM 699k</li>
        <li role="option" aria-selected="false" data-value="700+">RM 700k ke atas</li>
      </ul>
    </div>
  </div>
  <button class="filter-bar__sort" type="button" aria-label="Susun mengikut">
    <span class="filter-bar__icon" aria-hidden="true">
      <ArrowUpDown size={24} />
    </span>
  </button>
</form>

<style>
  /* ── Grid structure (mobile) ─────────────────────────────── */
  .filter-bar {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    column-gap: var(--space-3);
    row-gap: var(--space-3);
  }

  .filter-bar__search  { grid-column: 1; grid-row: 1; }
  .filter-bar__toggle  { grid-column: 2; grid-row: 1; }
  .filter-bar__sort    { grid-column: 3; grid-row: 1; }
  .filter-bar__buttons {
    grid-column: 1 / -1;
    grid-row: 2;
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
  }

  /* ── Shared appearance ──────────────────────────────────── */
  .filter-bar__search,
  .filter-bar__select,
  .filter-bar__toggle {
    height: 3rem;
    border-radius: var(--radius-small);
    background: var(--color-light-200);
    border: var(--border-width-main) solid var(--theme-border);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0 var(--space-2);
  }

  .filter-bar__select { width: 100%; }

  /* ── Revealed when panel is open ────────────────────────── */
  .filter-bar.is-open .filter-bar__buttons { display: flex; }

  /* ── Desktop ─────────────────────────────────────────────── */
  @media (min-width: 48rem) {
    .filter-bar {
      grid-template-columns: repeat(3, 1fr);
      align-items: center;
      gap: var(--space-3);
      position: relative;
    }

    .filter-bar__toggle  { display: none; }
    .filter-bar__search  { grid-column: 1;      grid-row: 1; }
    .filter-bar__buttons { grid-column: 2 / -1; grid-row: 1; display: flex; flex-direction: row; align-items: center; gap: var(--space-3); padding-right: calc(1.5rem + var(--space-3)); }
    .filter-bar__sort    { position: absolute; right: 0; top: 50%; transform: translateY(-50%); }

    .filter-bar__select { flex: 1 1 0; width: auto; min-width: 0; }
  }

  @media (min-width: 64rem) {
    .filter-bar { gap: var(--space-6); }
    .filter-bar__buttons { gap: var(--space-6); padding-right: calc(1.5rem + var(--space-6)); }
  }

  /* ── Component styles ───────────────────────────────────── */
  .filter-bar__search { cursor: text; }

  .filter-bar__search input {
    flex: 1 1 auto;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-huge);
    color: var(--theme-text);
  }
  .filter-bar__search input::placeholder {
    color: color-mix(in srgb, var(--theme-text) 40%, transparent);
  }

  .filter-bar__toggle {
    cursor: pointer;
    color: var(--theme-text);
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-huge);
    transition: border-color .2s ease;
    position: relative;
  }
  .filter-bar__toggle:hover { border-color: var(--theme-text); }

  .filter-bar__select {
    justify-content: space-between;
    color: var(--theme-text);
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-huge);
    cursor: pointer;
    transition: border-color .2s ease;
    position: relative;
  }

  .filter-bar__select > span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .filter-bar__select:hover { border-color: var(--theme-text); }

  .filter-bar__sort {
    background: transparent;
    border: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    height: 1.5rem;
    cursor: pointer;
    color: var(--theme-text);
  }

  .filter-bar__icon {
    width: 1.5rem;
    height: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--theme-text);
    flex-shrink: 0;
  }

  .filter-bar__badge {
    position: absolute;
    top: -0.375rem;
    right: -0.375rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--color-brand-400);
    border: 0.125rem solid var(--color-light-200);
    display: none;
    pointer-events: none;
  }

  .filter-bar__select.has-value .filter-bar__badge,
  .filter-bar__toggle.has-value .filter-bar__badge {
    display: block;
  }

  /* ── Dropdown panels ─────────────────────────────────────── */
  .filter-bar__dropdown-wrap {
    position: relative;
    width: 100%;
  }

  .filter-bar__dropdown-wrap .filter-bar__select {
    width: 100%;
  }

  .filter-bar__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: var(--space-2);
    list-style: none;
    margin-inline: 0;
    padding: var(--space-2) 0;
    background: var(--color-light-200);
    border: var(--border-width-main) solid var(--theme-border);
    border-radius: var(--radius-small);
    z-index: 10;
    display: none;
  }

  .filter-bar__dropdown-wrap.is-open .filter-bar__dropdown {
    display: block;
  }

  .filter-bar__dropdown [role="option"] {
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    color: var(--theme-text);
  }

  .filter-bar__dropdown [role="option"]:hover {
    background: color-mix(in srgb, var(--theme-text) 8%, transparent);
  }

  .filter-bar__dropdown [role="option"][aria-selected="true"] {
    background: color-mix(in srgb, var(--theme-text) 12%, transparent);
  }

  @media (min-width: 48rem) {
    .filter-bar__dropdown-wrap {
      flex: 1 1 0;
      width: auto;
      min-width: 0;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('.filter-bar');
  const toggle = form?.querySelector<HTMLButtonElement>('.filter-bar__toggle');
  const searchInput = form?.querySelector<HTMLInputElement>('input[name="q"]');

  toggle?.addEventListener('click', () => {
    const open = form!.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', () => {
    form?.querySelectorAll<HTMLElement>('.filter-bar__dropdown-wrap.is-open').forEach(wrap => {
      wrap.classList.remove('is-open');
      wrap.querySelector<HTMLButtonElement>('.filter-bar__select')?.setAttribute('aria-expanded', 'false');
    });
  });

  const activeFilters: Record<string, string> = {};

  function applyFilters(): void {
    const query = searchInput?.value.toLowerCase().trim() ?? '';
    document.querySelectorAll<HTMLLIElement>('[data-location]').forEach(item => {
      let show = true;
      for (const [group, value] of Object.entries(activeFilters)) {
        if (value && item.dataset[group] !== value) { show = false; break; }
      }
      if (show && query) {
        const heading  = item.querySelector('.card__heading')?.textContent?.toLowerCase() ?? '';
        const location = item.querySelector('.card__location')?.textContent?.toLowerCase() ?? '';
        show = heading.includes(query) || location.includes(query);
      }
      item.hidden = !show;
    });
  }

  function updateToggleBadge(): void {
    toggle?.classList.toggle('has-value', Object.values(activeFilters).some(v => v !== ''));
  }

  form?.querySelectorAll<HTMLElement>('.filter-bar__dropdown-wrap[data-filter-group]').forEach(wrap => {
    const group        = wrap.dataset.filterGroup!;
    const btn          = wrap.querySelector<HTMLButtonElement>('.filter-bar__select');
    const label        = btn?.querySelector<HTMLSpanElement>('span:first-child');
    const list         = wrap.querySelector<HTMLElement>('.filter-bar__dropdown');
    const defaultLabel = label?.textContent?.trim() ?? '';

    activeFilters[group] = '';

    btn?.addEventListener('click', e => {
      e.stopPropagation();
      form?.querySelectorAll<HTMLElement>('.filter-bar__dropdown-wrap').forEach(other => {
        if (other !== wrap) {
          other.classList.remove('is-open');
          other.querySelector<HTMLButtonElement>('.filter-bar__select')?.setAttribute('aria-expanded', 'false');
        }
      });
      const open = wrap.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
    });

    list?.querySelectorAll<HTMLElement>('[role="option"]').forEach(option => {
      option.addEventListener('click', e => {
        e.stopPropagation();
        const value = option.dataset.value ?? '';
        list.querySelectorAll('[role="option"]').forEach(o => o.setAttribute('aria-selected', 'false'));
        option.setAttribute('aria-selected', 'true');
        label!.textContent = value ? (option.textContent ?? defaultLabel) : defaultLabel;
        btn!.classList.toggle('has-value', value !== '');
        activeFilters[group] = value;
        updateToggleBadge();
        applyFilters();
        wrap.classList.remove('is-open');
        btn!.setAttribute('aria-expanded', 'false');
      });
    });
  });

  searchInput?.addEventListener('input', applyFilters);
</script>
