---
import { ArrowRight } from '@lucide/astro';
---

<section class="hero" data-screen-label="01 Hero" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-grid">
      <h1 class="hero-headline">Pakar Pemasaran Hartanah</h1>
      <div class="hero-side">
        <p>
          Sedia membantu anda menguruskan proses jualan atau sewaan hartanah
          melalui pendekatan yang sistematik dan telus, bagi memastikan
          urusan aset anda berjalan dengan lancar dan teratur.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="http://wasap.my/60176515784/UrusHartanah" target="_blank" rel="noopener noreferrer">
            Urus Hartanah
            <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </div>
    <article class="id-card" aria-label="Mengenai Fikry Zulkifly">
      <p class="id-blurb">
        Saya seorang Perunding Hartanah berdaftar
        <b>(REN&nbsp;71735)</b> dengan pengalaman selama 5&nbsp;tahun, dan
        telah berjaya membantu pemilik menyewakan serta menjual
        <b>lebih daripada 100&nbsp;unit hartanah</b>!
      </p>
      <h2 class="id-name">Fikry Zulkifly</h2>
      <div class="id-portrait-slot" aria-hidden="true"></div>
      <div
        class="id-portrait"
        role="img"
        aria-label="Potret Fikry Zulkifly"
      >
      </div>
    </article>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    border-radius: 0 0 var(--radius-main) var(--radius-main);
    overflow: hidden;
    background: var(--color-dark-900);
    isolation: isolate;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-brand-800) 55%, transparent) 0%,
        color-mix(in srgb, var(--color-dark-900) 78%, transparent) 100%
      ),
      url("/images/modern-house.png") center / cover no-repeat;
    animation: hero-bg-zoom 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  @keyframes hero-bg-zoom {
    from { transform: scale(1.08); }
    to   { transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero::before {
      animation: none;
    }
  }
  .hero-inner {
    position: relative;
    max-width: var(--max-width-main);
    margin-inline: auto;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: calc(var(--space-8) + var(--space-8)) var(--space-7);
    padding-inline: var(--margin);
    color: var(--color-light-100);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }
  .hero-headline {
    font-family: var(--font-family);
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-h1);
    line-height: var(--line-height-small);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-light-100);
    max-width: var(--max-width-small);
    margin: 0;
  }
  .hero-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-1);
  }
  .hero-side p {
    font-family: var(--font-family);
    font-size: var(--font-size-large);
    line-height: var(--line-height-large);
    color: var(--color-light-100);
    max-width: var(--max-width-small);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .id-card {
    display: none;
    position: relative;
    margin-top: calc(var(--space-8) * 6);
    background: var(--color-light-100);
    color: var(--color-dark-900);
    border-radius: var(--radius-main);
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr) clamp(9rem, 13vw, 12rem);
    gap: var(--space-7);
    align-items: center;
    padding: var(--space-5) var(--space-6);
    box-shadow: 0 var(--space-5) var(--space-7)
      color-mix(in srgb, var(--color-dark-900) 18%, transparent);
  }
  .id-blurb {
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    line-height: var(--line-height-large);
    color: var(--color-dark-900);
    max-width: var(--max-width-small);
  }
  .id-blurb b {
    font-weight: var(--font-weight-bold);
    color: inherit;
  }
  .id-name {
    font-family: var(--font-family);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-h3);
    line-height: var(--line-height-small);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-dark-900);
    margin: 0;
    text-align: center;
  }
  .id-portrait {
    position: absolute;
    right: var(--space-6);
    bottom: 0;
    width: clamp(9rem, 13vw, 12rem);
    aspect-ratio: 642 / 1039;
    border-radius: var(--radius-main);
    overflow: hidden;
    background: url("/images/FZ.webp") center / cover no-repeat;
  }
  .id-portrait-slot {
    align-self: stretch;
  }

  @media (min-width: 80rem) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--gutter);
    }
    .id-card { display: grid; }
  }
</style>
