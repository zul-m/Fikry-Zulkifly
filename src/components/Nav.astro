<style>
  /* -----------------------------------------------------------------------
     NAV ANIMATION TIMINGS
  ----------------------------------------------------------------------- */
  .nav_component {
    --nav-menu-open-duration:     400ms;
    --nav-menu-close-duration:    400ms;
    --nav-dropdown-open-duration: 400ms;
    --nav-dropdown-close-duration:400ms;
    --nav-highlight-speed:        400ms;
  }

  /* -----------------------------------------------------------------------
     NAV COMPONENT — wrapper
  ----------------------------------------------------------------------- */
  .nav_component {
    z-index: 1000;
    pointer-events: none;
    background-color: transparent;
    position: sticky;
    inset: 0 0 auto;
    container-type: inline-size;
  }

  /* Overlap variant — nav sits on top of hero */
  .nav_component.is-overlap {
    position: absolute;
  }

  /* -----------------------------------------------------------------------
     SKIP LINK
  ----------------------------------------------------------------------- */
  .nav_skip_wrap {
    z-index: 2;
    border-width: var(--border-width-main);
    border-style: solid;
    border-color: var(--theme-border);
    border-radius: var(--nav-radius);
    background-color: var(--theme-background);
    color: var(--theme-text);
    outline-offset: var(--focus-offset-inner);
    pointer-events: auto;
    margin: 0.5rem;
    padding: 0.5rem;
    position: absolute;
    inset: 0 auto auto 0;
    transform: translate(-200%);
    text-decoration: none;
    font-size: var(--font-size-small);
    transition: transform 0.2s;
  }
  .nav_skip_wrap:focus {
    transform: translate(0%);
  }

  /* -----------------------------------------------------------------------
     LOGO SIZE
  ----------------------------------------------------------------------- */
  .nav_logo_size {
    width: 11rem;
    max-width: 100%;
  }
  .nav_logo_size img {
    width: 100%;
    display: block;
  }

  /* -----------------------------------------------------------------------
     DESKTOP NAV — hidden by default, shown at >= 65em container
  ----------------------------------------------------------------------- */
  .nav_desktop_wrap {
    z-index: 1;
    background-color: transparent;
    display: none;
    position: relative;
  }

  .nav_desktop_contain {
    max-width: var(--nav-max-width);
    padding-inline: var(--nav-spacing-inner);
    border-radius: var(--nav-radius);
    width: calc(100% - var(--nav-spacing-horizontal) * 2);
    margin-inline: auto;
  }

  .nav_desktop_layout {
    width: 100%;
    height: var(--nav-height);
    max-width: var(--nav-max-width);
    gap: var(--space-3);
    pointer-events: auto;
    justify-content: space-between;
    align-items: center;
    margin-inline: auto;
    display: flex;
  }

  .nav_desktop_logo {
    z-index: 2;
    outline-offset: var(--focus-offset-inner);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    position: relative;
  }

  /* -----------------------------------------------------------------------
     NAV LINKS COMPONENT (shared desktop + mobile)
  ----------------------------------------------------------------------- */
  .nav_links_component {
    padding-block: var(--space-3) var(--space-8);
    gap: var(--space-3);
    flex-direction: column;
    flex: 1;
    display: flex;
  }

  /* Desktop variant: horizontal row */
  .nav_links_component.is-desktop {
    flex-direction: row;
    padding-block: 0;
    align-items: stretch;
    height: 100%;
  }

  .nav_links_wrap {
    flex: 1;
  }

  .nav_links_component.is-desktop .nav_links_wrap {
    flex-direction: row;
    justify-content: center;
    align-items: stretch;
    display: flex;
  }

  .nav_links_item {
    display: flex;
  }

  /* -----------------------------------------------------------------------
     DROPDOWN COMPONENT
  ----------------------------------------------------------------------- */
  .nav_dropdown_component {
    width: 100%;
    height: 100%;
    z-index: unset;
    position: static;
  }

  /* Trigger button */
  .nav_links_link {
    z-index: 2;
    width: 100%;
    padding-block: var(--space-2);
    gap: var(--space-2);
    cursor: pointer;
    color: inherit;
    background: none;
    border: none;
    font: inherit;
    font-size: var(--font-size-body);
    flex: 1;
    justify-content: flex-start;
    align-items: center;
    display: flex;
    position: relative;
    outline-offset: var(--focus-offset-inner);
  }

  .nav_links_component.is-desktop .nav_links_link {
    height: 100%;
    padding-inline: var(--space-3);
    padding-block: 0;
  }

  .nav_links_svg {
    width: 1rem;
    flex: none;
    margin-left: auto;
    transition: transform 0.2s ease;
    overflow: visible;
    display: flex;
    align-items: center;
  }

  /* Arrow rotates when dropdown is open */
  .nav_dropdown_component:has(.nav_links_link[aria-expanded="true"]) .nav_links_svg {
    transform: rotate(90deg);
  }

  /* -----------------------------------------------------------------------
     DROPDOWN LIST — grid height animation
  ----------------------------------------------------------------------- */
  .nav_dropdown_main_wrap {
    background-color: transparent;
    width: 22.5rem;
    min-width: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--nav-dropdown-close-duration) ease,
                visibility var(--nav-dropdown-close-duration) ease,
                opacity var(--nav-dropdown-close-duration) ease;
    visibility: hidden;
    opacity: 0;
    position: relative;
  }

  /* Desktop: absolutely positioned below trigger */
  .nav_links_component.is-desktop .nav_dropdown_main_wrap {
    padding-top: var(--space-1);
    position: absolute;
    top: 100%;
  }

  /* Open state — via hover (desktop) or aria-expanded (both) */
  @media (hover: hover) {
    .nav_links_component.is-desktop .nav_dropdown_component:hover .nav_dropdown_main_wrap {
      grid-template-rows: 1fr;
      visibility: visible;
      opacity: 1;
      transition-duration: var(--nav-dropdown-open-duration);
    }
  }

  .nav_dropdown_component:has(.nav_links_link[aria-expanded="true"]) .nav_dropdown_main_wrap {
    grid-template-rows: 1fr;
    visibility: visible;
    opacity: 1;
    transition-duration: var(--nav-dropdown-open-duration);
  }

  .nav_dropdown_main_content {
    overflow: hidden;
  }

  .nav_dropdown_main_scroll {
    border-radius: var(--nav-radius);
    background-color: var(--theme-nav-background);
    max-height: calc(100svh - var(--nav-height-total) - var(--nav-spacing-vertical) * 2);
    overflow-x: hidden;
    overflow-y: auto;
  }

  .nav_dropdown_list {
    display: flex;
    flex-direction: column;
  }

  .nav_dropdown_item {
    display: block;
  }

  .nav_dropdown_link {
    z-index: 2;
    width: 100%;
    padding-block: var(--space-2);
    padding-inline: calc(var(--space-8) / 2);
    border-bottom: var(--border-width-main) solid var(--theme-border);
    cursor: pointer;
    color: inherit;
    font-size: var(--font-size-small);
    display: block;
    text-decoration: none;
    outline-offset: var(--focus-offset-inner);
    transition: color 0.15s ease;
  }

  .nav_dropdown_link:hover .nav_dropdown_heading {
    color: var(--theme-selection-background);
  }

  .nav_dropdown_heading {
    display: block;
    transition: opacity 0.1s;
  }

  .nav_dropdown_text {
    opacity: 0.6;
    font-size: var(--font-size-small);
    margin-top: 0.125rem;
    display: block;
    transition: opacity 0.1s;
  }

  /* -----------------------------------------------------------------------
     ACTIONS (socials + CTA)
  ----------------------------------------------------------------------- */
  .nav_actions_wrap {
    flex-direction: column-reverse;
    flex: none;
    display: flex;
  }

  .nav_actions_wrap.is-desktop {
    flex-direction: row;
    justify-content: flex-start;
    align-items: center;
  }

  /* Socials */
  .nav_socials_item {
    justify-content: space-around;
    display: flex;
  }

  .nav_socials_item.is-desktop {
    gap: var(--space-4);
    align-items: center;
  }

  .nav_social_link {
    width: 1.3rem;
    padding-block: 0.5rem;
    display: block;
    color: inherit;
    transition: opacity 0.2s ease;
  }
  .nav_social_link:hover {
    opacity: 0.7;
  }
  .nav_social_link.is-facebook {
    width: 0.7rem;
  }
  .nav_social_link.is-tiktok {
    width: 1.1rem;
  }
  .nav_social_link svg {
    width: 100%;
    display: block;
  }

  /* CTA button */
  .nav_buttons_item {
    z-index: 2;
    padding-block: var(--space-2);
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    position: relative;
  }

  .nav_buttons_item.is-desktop {
    margin-left: var(--space-4);
    padding-block: 0;
  }

  /* -----------------------------------------------------------------------
     MOBILE NAV
  ----------------------------------------------------------------------- */
  .nav_mobile_wrap {
    z-index: 1;
    background-color: transparent;
    position: relative;
  }

  .nav_mobile_contain {
    max-width: var(--nav-max-width);
    width: calc(100% - var(--nav-spacing-horizontal) * 2);
    margin-inline: auto;
  }

  .nav_mobile_layout {
    z-index: 2;
    width: 100%;
    height: var(--nav-height);
    padding-inline: var(--nav-spacing-inner);
    gap: var(--space-3);
    border-radius: var(--nav-radius);
    pointer-events: auto;
    justify-content: space-between;
    align-items: center;
    margin-inline: auto;
    display: flex;
    position: relative;
  }

  .nav_mobile_logo {
    z-index: 2;
    outline-offset: var(--focus-offset-inner);
    display: flex;
    align-items: center;
    position: relative;
  }

  /* Mobile menu panel */
  .nav_mobile_menu_wrap {
    max-width: var(--nav-max-width);
    padding-top: var(--nav-height);
    border-radius: var(--nav-radius);
    background-color: var(--theme-nav-background);
    pointer-events: auto;
    width: calc(100% - var(--nav-spacing-horizontal) * 2);
    margin-inline: auto;
    inset: 0 0 auto;
    transform: none;
    /* hidden by default */
    clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
    position: absolute;
    z-index: 1;
    top: 0;
  }

  .nav_mobile_menu_wrap[aria-hidden="false"] {
    animation: menuOpen var(--nav-menu-open-duration) ease-in-out forwards;
  }

  .nav_mobile_menu_wrap[aria-hidden="true"] {
    animation: menuClose var(--nav-menu-close-duration) ease-in-out forwards;
  }

  .nav_mobile_menu_scroll {
    padding-inline: var(--nav-spacing-inner);
    max-height: calc(100svh - var(--nav-height-total) - var(--nav-spacing-vertical) * 2);
    overflow: hidden auto;
  }

  /* Mobile dropdown: always shown as expanded list */
  .nav_mobile_wrap .nav_dropdown_main_wrap {
    width: 100%;
    position: static;
    grid-template-rows: 1fr;
    visibility: visible;
    opacity: 1;
    transition: grid-template-rows 0.3s ease;
  }

  .nav_mobile_wrap .nav_dropdown_component:not(:has(.nav_links_link[aria-expanded="true"])) .nav_dropdown_main_wrap {
    grid-template-rows: 0fr;
    visibility: hidden;
    opacity: 0;
  }

  .nav_mobile_wrap .nav_dropdown_main_scroll {
    border-radius: 0;
    background-color: transparent;
    max-height: none;
    overflow: visible;
  }

  /* -----------------------------------------------------------------------
     HAMBURGER BUTTON
  ----------------------------------------------------------------------- */
  .nav_button_wrap {
    z-index: 2;
    flex: none;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    pointer-events: auto;
    outline-width: var(--focus-width);
    outline-color: var(--theme-text);
    outline-offset: var(--focus-offset-inner);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav_button_layout {
    gap: var(--nav-hamburger-gap);
    pointer-events: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    display: flex;
    position: relative;
  }

  .nav_button_line {
    width: 100%;
    height: var(--nav-hamburger-thickness);
    background-color: currentColor;
    flex: none;
    transition: transform 0.2s ease;
    display: block;
  }

  /* Hamburger → X when open */
  .nav_button_wrap[aria-expanded="true"] .nav_button_line.is-1 {
    transform: translateY(calc(var(--nav-hamburger-thickness) * 0.5 + var(--nav-hamburger-gap) * 0.5)) rotate(-45deg);
  }
  .nav_button_wrap[aria-expanded="true"] .nav_button_line.is-2 {
    transform: translateY(calc(var(--nav-hamburger-thickness) * -0.5 + var(--nav-hamburger-gap) * -0.5)) rotate(45deg);
  }

  /* -----------------------------------------------------------------------
     BACKDROPS
  ----------------------------------------------------------------------- */
  .nav_menu_backdrop {
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    background-color: color-mix(in srgb, var(--color-dark-900) 20%, transparent);
    width: 100%;
    height: 100vh;
    position: absolute;
    inset: 0;
    transition: opacity var(--nav-menu-close-duration) ease;
  }

  .nav_menu_backdrop {
    display: block;
  }

  /* Show menu backdrop when mobile menu is open */
  .nav_component:has(.nav_button_wrap[aria-expanded="true"]) .nav_menu_backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  /* -----------------------------------------------------------------------
     RESPONSIVE — container query switches desktop ↔ mobile
  ----------------------------------------------------------------------- */
  @container (min-width: 65em) {
    .nav_desktop_wrap {
      display: block;
    }
    .nav_mobile_wrap,
    .nav_menu_backdrop {
      display: none;
    }
  }

  /* Lock body scroll when mobile menu is open */
  @media (width < 65em) {
    :global(body:has(.nav_button_wrap[aria-expanded="true"])) {
      overflow: hidden;
    }
  }

  /* -----------------------------------------------------------------------
     ANIMATIONS — mobile menu open / close
  ----------------------------------------------------------------------- */
  @keyframes menuOpen {
    from { clip-path: polygon(0 0, 100% 0, 100% 0, 0 0); }
    to   { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
  }

  @keyframes menuClose {
    from { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
    to   { clip-path: polygon(0 0, 100% 0, 100% 0, 0 0); }
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(isOpen));
  });

  document.querySelectorAll('.nav_links_link[aria-haspopup="true"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      const wrap = btn.closest('.nav_links_wrap');
      wrap?.querySelectorAll('.nav_links_link[aria-expanded="true"]').forEach((other) => {
        if (other !== btn) other.setAttribute('aria-expanded', 'false');
      });

      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.nav_dropdown_component')) {
      document.querySelectorAll('.nav_links_link[aria-expanded="true"]').forEach((btn) => {
        btn.setAttribute('aria-expanded', 'false');
      });
    }
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
