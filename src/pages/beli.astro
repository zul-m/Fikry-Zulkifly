---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FilterBar from '@components/FilterBar.astro';
import PropertyCard from '@components/PropertyCard.astro';
import { sanityClient } from 'sanity:client';
import '@styles/beli.css';
import { LOCATION_OPTIONS, PROPERTY_TYPE_OPTIONS } from '../sanity/constants';

const locationLabels = Object.fromEntries(LOCATION_OPTIONS.map(o => [o.value, o.title]));
const typeLabels = Object.fromEntries(PROPERTY_TYPE_OPTIONS.map(o => [o.value, o.title]));

const rawProjects = await sanityClient.fetch<{
  _id: string;
  slug: string;
  title: string;
  location: string;
  propertyType: string;
  priceFrom: number;
  imageUrl: string | null;
}[]>(`
  *[_type == "newProject" && !(_id in path("drafts.**"))] | order(publishedAt desc) {
    _id,
    "slug": slug.current,
    title,
    location,
    propertyType,
    priceFrom,
    "imageUrl": image.asset->url
  }
`);

const locationOptions = [...new Set(rawProjects.map(p => p.location))].map(v => ({
  value: v,
  label: locationLabels[v] ?? v,
}));

const typeOptions = [...new Set(rawProjects.map(p => p.propertyType).filter(Boolean))].map(v => ({
  value: v,
  label: typeLabels[v] ?? v,
}));

function priceBucket(price: number): string {
  if (price < 300_000) return '200-299';
  if (price < 400_000) return '300-399';
  if (price < 500_000) return '400-499';
  if (price < 600_000) return '500-599';
  if (price < 700_000) return '600-699';
  return '700+';
}

const properties = rawProjects.map((p) => ({
  slug: p.slug,
  title: p.title,
  location: locationLabels[p.location] ?? p.location,
  locationKey: p.location,
  typeKey: p.propertyType,
  priceKey: priceBucket(p.priceFrom),
  price: `RM ${p.priceFrom.toLocaleString("en-MY")}`,
  status: "Projek baru",
  image: p.imageUrl ?? undefined,
}));

const crumbs = [
  { href: "/",  label: "Laman utama" },
  {             label: "Beli"        },
];
---

<Layout
  title="Beli — FZ Property"
  description="Semak senarai hartanah terkini untuk dibeli — projek baru, subsale dan lelong di Selangor."
>
  <section
    class="buy"
    data-theme="light"
    data-screen-label="01 Beli — Subsale"
    aria-labelledby="buy-heading"
  >
    <div class="buy-inner">
      <h1 id="buy-heading" class="sr-only">Beli — Senarai hartanah</h1>

      <Breadcrumbs items={crumbs} />

      <div class="buy__content">
        <FilterBar locationOptions={locationOptions} typeOptions={typeOptions} />

        <ul class="buy__grid" role="list">
          {properties.map((p) => (
            <li data-location={p.locationKey} data-type={p.typeKey} data-price={p.priceKey}><PropertyCard property={p} /></li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Layout>
