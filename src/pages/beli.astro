---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FilterBar from '@components/FilterBar.astro';
import PropertyCard from '@components/PropertyCard.astro';
import { sanityClient } from 'sanity:client';
import '@styles/beli.css';

const locationLabels: Record<string, string> = {
  "presint-7-putrajaya": "Presint 7, Putrajaya",
};

const rawProjects = await sanityClient.fetch<{
  _id: string;
  slug: string;
  title: string;
  location: string;
  priceFrom: number;
  imageUrl: string | null;
}[]>(`
  *[_type == "newProject"] | order(publishedAt desc) {
    _id,
    "slug": slug.current,
    title,
    location,
    priceFrom,
    "imageUrl": image.asset->url
  }
`);

const properties = rawProjects.map((p) => ({
  slug: p.slug,
  title: p.title,
  location: locationLabels[p.location] ?? p.location,
  price: `RM ${p.priceFrom.toLocaleString("en-MY")}`,
  status: "Projek baru",
  image: p.imageUrl ?? undefined,
}));

const crumbs = [
  { href: "/",  label: "Laman utama" },
  {             label: "Beli"        },
];
---

<Layout
  title="Beli — FZ Property"
  description="Semak senarai hartanah terkini untuk dibeli — projek baru, subsale dan lelong di Selangor."
>
  <section
    class="buy"
    data-theme="light"
    data-screen-label="01 Beli — Subsale"
    aria-labelledby="buy-heading"
  >
    <div class="buy-inner">
      <h1 id="buy-heading" class="sr-only">Beli — Senarai hartanah</h1>

      <Breadcrumbs items={crumbs} />

      <div class="buy__content">
        <FilterBar />

        <ul class="buy__grid" role="list">
          {properties.map((p) => (
            <li data-location={p.location}><PropertyCard property={p} /></li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Layout>
