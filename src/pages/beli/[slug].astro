---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { Aperture, ArrowLeft, Baby, Bath, BedDouble, Building2, Car, ChevronDown, ChevronLeft, ChevronRight, CircleDot, CloudRain, Dumbbell, EvCharger, Flame, Footprints, Gamepad2, Goal, Landmark, LayoutGrid, Library, Ruler, School, ShieldCheck, Store, Tent, ThermometerSun, ToyBrick, Trees, Volleyball, WashingMachine, WavesLadder, X } from '@lucide/astro';
import { sanityClient } from 'sanity:client';
import '@styles/beli-item.css';
import { AMENITY_ICON_OPTIONS, LOCATION_OPTIONS, PROPERTY_TYPE_OPTIONS } from '../../sanity/constants';
import { sanityImageUrl } from '../../sanity/image';

type Block = {
  _type: 'block';
  _key: string;
  style?: string;
  children?: Array<{ _type: string; text: string; marks?: string[] }>;
};

type Project = {
  _id: string;
  title: string;
  slug: string;
  developer: string | null;
  location: string;
  priceFrom: number;
  propertyType: string;
  tenure: string | null;
  totalUnits: number | null;
  size: string | null;
  bedrooms: string | null;
  bathrooms: string | null;
  parking: string | null;
  completionYear: string | null;
  ctaLink: string | null;
  description: Block[] | null;
  imageUrl: string | null;
  gallery: string[];
  registrationOpen: boolean;
  amenities: string[] | null;
  publishedAt: string | null;
};

export async function getStaticPaths() {
  const projects = await sanityClient.fetch<Project[]>(`
    *[_type == "newProject" && !(_id in path("drafts.**"))] {
      _id,
      title,
      "slug": slug.current,
      developer,
      location,
      priceFrom,
      propertyType,
      tenure,
      totalUnits,
      size,
      bedrooms,
      bathrooms,
      parking,
      completionYear,
      ctaLink,
      description,
      "imageUrl": image.asset->url,
      "gallery": gallery[].asset->url,
      registrationOpen,
      amenities,
      publishedAt
    }
  `);

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const locationLabel =
  LOCATION_OPTIONS.find((o) => o.value === project.location)?.title ?? project.location;

const typeLabel =
  PROPERTY_TYPE_OPTIONS.find((o) => o.value === project.propertyType)?.title ?? project.propertyType;

const tenureLabels: Record<string, string> = {
  leasehold: 'Pajakan',
  freehold: 'Pegangan bebas',
  'malay-reserve': 'Tanah rezab melayu',
};

const priceFormatted = `RM ${project.priceFrom.toLocaleString('en-MY')}`;
const tenureLabel = project.tenure ? (tenureLabels[project.tenure] ?? project.tenure) : 'Tanah rezab melayu';
const loanPrincipal = project.priceFrom * 0.9;
const monthlyRate = 0.045 / 12;
const n = 35 * 12;
const monthlyPayment = loanPrincipal * (monthlyRate * Math.pow(1 + monthlyRate, n)) / (Math.pow(1 + monthlyRate, n) - 1);
const monthlyPaymentFormatted = `RM ${Math.round(monthlyPayment).toLocaleString('en-MY')}`;
const galleryUrls = project.gallery?.filter(Boolean) ?? [];
const allImages = [...new Set([
  ...(project.imageUrl ? [project.imageUrl] : []),
  ...galleryUrls,
])];
const imageIndexMap = new Map(allImages.map((url, i) => [url, i]));

function thumbUrl(index: number): string | undefined {
  return galleryUrls[index] ?? project.imageUrl ?? undefined;
}

const crumbs = [
  { href: '/', label: 'Laman utama' },
  { href: '/beli', label: 'Beli' },
  { label: project.title },
];

function renderBlocks(blocks: Block[]): string {
  return blocks
    .map((block) => {
      if (block._type !== 'block') return '';
      const inner =
        block.children
          ?.map((child) => {
            // Escape first — child.text is untrusted Sanity input fed into set:html.
            // Any new field added here must also be escaped before interpolation.
            let t = (child.text ?? '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;');
            if (child.marks?.includes('strong')) t = `<strong>${t}</strong>`;
            if (child.marks?.includes('em')) t = `<em>${t}</em>`;
            return t;
          })
          .join('') ?? '';
      switch (block.style ?? 'normal') {
        case 'h2':         return `<h2>${inner}</h2>`;
        case 'h3':         return `<h3>${inner}</h3>`;
        case 'h4':         return `<h4>${inner}</h4>`;
        case 'blockquote': return `<blockquote><p>${inner}</p></blockquote>`;
        default:           return inner ? `<p>${inner}</p>` : '';
      }
    })
    .join('');
}

const descriptionHtml = project.description?.length
  ? renderBlocks(project.description)
  : null;

const cardSpecs = [
  ...(project.bedrooms  != null ? [{ label: 'Bilik tidur', value: project.bedrooms,  icon: BedDouble }] : []),
  ...(project.bathrooms != null ? [{ label: 'Bilik air',   value: project.bathrooms, icon: Bath      }] : []),
  ...(project.parking   != null ? [{ label: 'Parkir',      value: project.parking,   icon: Car       }] : []),
  ...(project.size      != null ? [{ label: 'Saiz',        value: `${project.size} kp`,              icon: Ruler     }] : []),
];

const infoRows = [
  { key: 'Hak milik',   value: tenureLabel },
  ...(project.bedrooms     != null ? [{ key: 'Bilik tidur',     value: project.bedrooms    }] : []),
  ...(project.bathrooms    != null ? [{ key: 'Bilik air',       value: project.bathrooms   }] : []),
  ...(project.parking      != null ? [{ key: 'Parkir',          value: project.parking     }] : []),
  ...(project.size         != null ? [{ key: 'Saiz',            value: `${project.size} kaki persegi`         }] : []),
  ...(project.totalUnits   != null ? [{ key: 'Jumlah unit',     value: `${project.totalUnits} unit`           }] : []),
  ...(project.completionYear       ? [{ key: 'Tahun siap',      value: project.completionYear                 }] : []),
  ...(project.developer            ? [{ key: 'Pemaju',          value: project.developer                      }] : []),
  { key: 'Jenis',       value: typeLabel },
];

const AMENITY_ICON_MAP: Partial<Record<string, typeof Dumbbell>> = {
  'dumbbell':        Dumbbell,
  'trees':           Trees,
  'flame':           Flame,
  'building-2':      Building2,
  'gamepad-2':       Gamepad2,
  'landmark':        Landmark,
  'goal':            Goal,
  'aperture':        Aperture,
  'baby':            Baby,
  'toy-brick':       ToyBrick,
  'waves-ladder':    WavesLadder,
  'washing-machine': WashingMachine,
  'store':           Store,
  'library':         Library,
  'volleyball':      Volleyball,
  'school':          School,
  'cloud-rain':      CloudRain,
  'shield-check':    ShieldCheck,
  'tent':            Tent,
  'circle-dot':      CircleDot,
  'footprints':        Footprints,
  'ev-charger':        EvCharger,
  'thermometer-sun':   ThermometerSun,
};

const amenities = (project.amenities ?? [])
  .map((value) => {
    const option = AMENITY_ICON_OPTIONS.find((o) => o.value === value);
    const icon = AMENITY_ICON_MAP[value];
    return option && icon ? { label: option.title, icon } : null;
  })
  .filter((x): x is { label: string; icon: typeof Dumbbell } => x !== null)
  .sort((a, b) => a.label.localeCompare(b.label, "ms"));
---

<Layout
  title={`${project.title} — FZ Property`}
  description={`Projek baru ${project.title} di ${locationLabel}. Harga dari ${priceFormatted}.`}
>
  <section class="item" data-theme="light" aria-labelledby="item-heading">
    <div class="item-inner">
      <div class="item-breadcrumbs">
        <Breadcrumbs items={crumbs} />
      </div>
      <!-- Gallery -->
      <div class="gallery">
        <div
          class="gallery-main"
          aria-label={`${project.title} — galeri gambar`}
          data-lightbox-index={allImages.length > 0 ? 0 : undefined}
        >
          <a class="item-back" href="/beli" aria-label="Kembali ke halaman sebelumnya">
            <ArrowLeft size={20} aria-hidden="true" />
          </a>
          <div class="gallery-track">
            {allImages.map((url) => (
              <div class="gallery-slide" style={`background-image: url('${sanityImageUrl(url, 1600)}')`} />
            ))}
          </div>
          {allImages.length > 1 && (
            <span class="gallery-counter" aria-live="polite">1 / {allImages.length}</span>
          )}
        </div>
        <div class="gallery-grid">
          {[0, 1, 2, 3].map((i) => {
            const url = thumbUrl(i);
            const isTopRight    = i === 1;
            const isBottomRight = i === 3;
            return (
              <div
                class:list={[
                  'gallery-thumb',
                  isTopRight    && 'gallery-thumb--tr',
                  isBottomRight && 'gallery-thumb--br',
                ]}
                role="img"
                aria-label={`${project.title} — gambar ${i + 2}`}
                style={url ? `background-image: url('${sanityImageUrl(url, 480)}')` : undefined}
                data-lightbox-index={url ? imageIndexMap.get(url) : undefined}
              >
                {isBottomRight && (
                  <button class="btn btn-secondary btn-light gallery-cta" type="button">
                    <LayoutGrid size={20} aria-hidden="true" />
                    Lihat semua gambar
                  </button>
                )}
              </div>
            );
          })}
        </div>
      </div>
      <!-- Body two-column -->
      <div class="body-cols">
        <!-- Left: description -->
        <div class="description">
          <header class="desc-header">
            <h1 id="item-heading" class="desc-title">{project.title}</h1>
            <span class="desc-location">{locationLabel}</span>
          </header>
          <div class="desc-body">
            <!-- Prose -->
            {descriptionHtml && (
              <div class="desc-prose" set:html={descriptionHtml} />
            )}
            <!-- Info table -->
            <section class="desc-section" aria-labelledby="info-lanjut-label">
              <h2 class="section-heading" id="info-lanjut-label">Info lanjut</h2>
              <div class="info-table" role="table" aria-label="Maklumat hartanah">
                {infoRows.map(({ key, value }) => (
                  <>
                    <div class="cell key" role="rowheader">{key}</div>
                    <div class="cell val" role="cell">{value}</div>
                  </>
                ))}
                <div class="cell key amenities" role="rowheader">Kemudahan</div>
                <div class="cell val amenities" role="cell">
                  <ul class="amenity-list">
                    {amenities.map(({ label, icon: Icon }) => (
                      <li>
                        <Icon size={16} aria-hidden="true" class="amenity-icon" />
                        {label}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </section>
            <!-- Lokasi -->
            <section class="desc-section" aria-labelledby="lokasi-heading">
              <h2 class="section-heading" id="lokasi-heading">Lokasi</h2>
              <iframe
                class="lokasi-map"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src={`https://maps.google.com/maps?q=${encodeURIComponent(`${project.title}, ${locationLabel}`)}&output=embed`}
                title={`Peta lokasi ${project.title}`}
              />
            </section>
          </div>
        </div>
        <!-- Right: sticky info card -->
        <aside class="info-card" aria-label="Ringkasan hartanah">
          <div class="info-card-meta">
            <div class="info-card-info">
              <span class="info-card-tag">Projek baru</span>
              <span class="info-card-price">Dari {priceFormatted}</span>
            </div>
            <div class="info-card-title-block">
              <h2 class="info-card-title">{project.title}</h2>
              <span class="info-card-location">{locationLabel}</span>
            </div>
          </div>
          <div class="info-card-specs">
            {cardSpecs.map(({ label, value, icon: Icon }) => (
              <div class="spec-item">
                <Icon size={18} aria-hidden="true" class="spec-icon" />
                <span class="spec-value">{value}</span>
                <span class="spec-label">{label}</span>
              </div>
            ))}
          </div>
          <details class="calculator-section" open>
            <summary class="calculator-trigger">
              Anggaran bayaran bulanan
              <ChevronDown size={16} class="calculator-chevron" aria-hidden="true" />
            </summary>
            <div class="calculator-body">
              <span class="calculator-result-amount">{monthlyPaymentFormatted}<span class="calculator-result-unit">/bulan</span></span>
              <p class="info-card-disclaimer">Kiraan berdasarkan 10% dp, 4.5% p.a., 35 thn.</p>
            </div>
          </details>
          <div class="info-card-actions">
            <a href={project.ctaLink ?? '#contact'} class="btn btn-primary" {...(project.ctaLink ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Hubungi Saya
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
  {allImages.length > 0 && (
    <dialog id="gallery-lightbox" class="lightbox" aria-label="Galeri gambar">
      <div class="lightbox-slides">
        {allImages.map((url, i) => (
          <div class:list={['lightbox-slide', i === 0 && 'is-active']}>
            <img
              src={sanityImageUrl(url, 2000)}
              alt={`${project.title} — gambar ${i + 1}`}
              class="lightbox-img"
              draggable="false"
            />
          </div>
        ))}
      </div>
      <button class="lightbox-btn lightbox-close" aria-label="Tutup galeri" type="button">
        <X size={20} aria-hidden="true" />
      </button>
      {allImages.length > 1 && (
        <>
          <button class="lightbox-btn lightbox-prev" aria-label="Gambar sebelumnya" type="button">
            <ChevronLeft size={22} aria-hidden="true" />
          </button>
          <button class="lightbox-btn lightbox-next" aria-label="Gambar seterusnya" type="button">
            <ChevronRight size={22} aria-hidden="true" />
          </button>
          <div class="lightbox-counter-wrap">
            <span class="lightbox-counter" aria-live="polite">1 / {allImages.length}</span>
          </div>
        </>
      )}
    </dialog>
  )}
</Layout>

<script src="../../scripts/beli-item.ts"></script>