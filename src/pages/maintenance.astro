---
import '@styles/global.css';
import '@styles/maintenance.css';
---

<!doctype html>
<html lang="ms-MY" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Fikry Zulkifly | Sedang Diselenggara</title>
  <meta name="description" content="Laman web Fikry Zulkifly sedang dalam penyelenggaraan. Sila hubungi terus untuk pertanyaan hartanah." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/images/favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/images/webclip.jpg" />
</head>
<body>
  <main class="stage">
    <section class="hero" aria-labelledby="headline">
      <div class="eyebrow">
        <span class="eyebrow-bar" aria-hidden="true"></span>
        <span>Maaf atas kesulitan</span>
      </div>
      <h1 id="headline" class="display">
        Laman ini sedang<br />
        <span class="display-accent">diselenggara</span>.
      </h1>
      <p class="lede">
        Laman web ini sedang diselenggara. Untuk sebarang pertanyaan berkaitan jualan, sewaan dan rundingan hartanah, sila hubungi terus melalui pautan di bawah.
      </p>
    </section>
    <section class="meta" aria-label="Maklumat lanjut">
      <div class="meta-item">
        <div class="meta-label">Hubungi</div>
        <div class="meta-value">
          <a href="tel:+60176515784">+60 17-651 5784</a><br />
          <a href="mailto:fikryzulkiflyproperty@gmail.com">fikryzulkiflyproperty@gmail.com</a>
        </div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Alamat Pejabat</div>
        <div class="meta-value">
          Tamarind Square, Persiaran Multimedia,<br />
          Cyber 10, 63000 Cyberjaya,<br />
          Selangor Darul Ehsan.
        </div>
      </div>
    </section>
  </main>
</body>
</html>
